<Page
    x:Class="RDAT.Copilot.App.Views.TmPanelPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:RDAT.Copilot.App.Views"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Translation Memory" Style="{StaticResource TitleTextBlockStyle}" Margin="0,0,0,8"/>

        <AutoSuggestBox Grid.Row="1" x:Name="TmSearchBox"
                        QueryIcon="Find"
                        PlaceholderText="Search translation memory..."
                        TextChanged="TmSearchBox_TextChanged"
                        Margin="0,0,0,12"/>

        <ListView Grid.Row="2" x:Name="TmResultsList"
                  SelectionMode="Single"
                  IsItemClickEnabled="True"
                  ItemClick="TmResultsList_ItemClick">

            <ListView.Header>
                <Grid Padding="8,4" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Source" FontWeight="SemiBold" Opacity="0.7"/>
                    <TextBlock Grid.Column="1" Text="Target" FontWeight="SemiBold" Opacity="0.7"/>
                    <TextBlock Grid.Column="2" Text="Score" FontWeight="SemiBold" Opacity="0.7" HorizontalAlignment="Right"/>
                </Grid>
            </ListView.Header>

            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding Source}" TextWrapping="Wrap" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding Target}" TextWrapping="Wrap" FlowDirection="RightToLeft" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="{Binding Score}" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="{ThemeResource SystemFillColorSuccessBrush}" FontWeight="Bold"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>