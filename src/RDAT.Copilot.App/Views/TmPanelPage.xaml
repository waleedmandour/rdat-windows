<Page
    x:Class="RDAT.Copilot.App.Views.TmPanelPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:RDAT.Copilot.App.Views"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Translation Memory" Style="{StaticResource TitleTextBlockStyle}" Margin="0,0,0,8"/>

        <!-- Search box -->
        <AutoSuggestBox Grid.Row="1" x:Name="TmSearchBox"
                        QueryIcon="Find"
                        PlaceholderText="Search translation memory..."
                        TextChanged="TmSearchBox_TextChanged"
                        Margin="0,0,0,12"/>

        <!-- TM Results ListView -->
        <ListView Grid.Row="2" x:Name="TmResultsList"
                  SelectionMode="Single"
                  IsItemClickEnabled="True"
                  ItemClick="TmResultsList_ItemClick">

            <ListView.Header>
                <Grid Padding="8,4" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="Auto" MinWidth="80"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Source" FontWeight="SemiBold" Opacity="0.7"/>
                    <TextBlock Grid.Column="1" Text="Target" FontWeight="SemiBold" Opacity="0.7"/>
                    <TextBlock Grid.Column="2" Text="Score" FontWeight="SemiBold" Opacity="0.7"/>
                </Grid>
            </ListView.Header>

            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="8,6" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="Auto" MinWidth="80"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding Source}" TextWrapping="Wrap"/>
                        <TextBlock Grid.Column="1" Text="{Binding Target}" TextWrapping="Wrap" FlowDirection="RightToLeft"/>
                        <Border Grid.Column="2" Padding="8,4" CornerRadius="4"
                                Background="{ThemeResource SystemFillColorSuccessBrush}"
                                HorizontalAlignment="Center">
                            <TextBlock Text="{Binding Score}" FontWeight="SemiBold" FontSize="12"/>
                        </Border>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
