<Page
    x:Class="RDAT.Copilot.App.Views.TranslationWorkspacePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:RDAT.Copilot.App.Views"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Grid Grid.Row="0" Padding="12,8" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6">
                <Button x:Name="OpenButton" Click="OpenButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE8E5;" FontSize="14"/>
                        <TextBlock Text="Open"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="6">
                <ToggleButton x:Name="RtlToggle" Click="RtlToggle_Click">
                    <TextBlock Text="RTL"/>
                </ToggleButton>
            </StackPanel>
        </Grid>

        <!-- SplitView -->
        <SplitView Grid.Row="1"
                   x:Name="EditorSplitView"
                   DisplayMode="Inline"
                   IsPaneOpen="True"
                   OpenPaneLength="400"
                   PanePlacement="Left">

            <SplitView.Pane>
                <Grid Padding="4">
                    <Border BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="1">
                        <!-- Removed Source property to prevent compiler crash -->
                        <WebView2 x:Name="SourceWebView" />
                    </Border>
                </Grid>
            </SplitView.Pane>

            <Grid Padding="4">
                <Border BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="1">
                    <!-- Removed Source property to prevent compiler crash -->
                    <WebView2 x:Name="TargetWebView" />
                </Border>
            </Grid>
        </SplitView>

        <!-- Status bar -->
        <Grid Grid.Row="2" Padding="12,4">
            <TextBlock x:Name="StatusText" Text="Ready" FontSize="12" Opacity="0.6"/>
        </Grid>
    </Grid>
</Page>