<Page
    x:Class="RDAT.Copilot.App.Views.TranslationWorkspacePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:RDAT.Copilot.App.Views"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Grid Grid.Row="0" Padding="12,8" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6">
                <Button x:Name="OpenButton" Click="OpenButton_Click" ToolTipService.ToolTip="Open File">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE8E5;" FontSize="14"/>
                        <TextBlock Text="Open"/>
                    </StackPanel>
                </Button>
                <Button x:Name="SaveButton" Click="SaveButton_Click" ToolTipService.ToolTip="Save File">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE74E;" FontSize="14"/>
                        <TextBlock Text="Save"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" Margin="12,0,0,0">
                <Button x:Name="PrevSegmentButton" Click="PrevSegmentButton_Click" ToolTipService.ToolTip="Previous Segment">
                    <FontIcon Glyph="&#xE830;" FontSize="14"/>
                </Button>
                <TextBlock x:Name="SegmentIndicator" Text="Segment 1 / 1" VerticalAlignment="Center" Margin="8,0" Opacity="0.7"/>
                <Button x:Name="NextSegmentButton" Click="NextSegmentButton_Click" ToolTipService.ToolTip="Next Segment">
                    <FontIcon Glyph="&#xE831;" FontSize="14"/>
                </Button>
            </StackPanel>

            <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="6">
                <ToggleButton x:Name="RtlToggle" Click="RtlToggle_Click" ToolTipService.ToolTip="Toggle RTL Mode">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE8B2;" FontSize="14"/>
                        <TextBlock Text="RTL"/>
                    </StackPanel>
                </ToggleButton>
            </StackPanel>
        </Grid>

        <!-- SplitView with source and target editors -->
        <SplitView Grid.Row="1"
                   x:Name="EditorSplitView"
                   DisplayMode="Inline"
                   IsPaneOpen="True"
                   OpenPaneLength="*"
                   PanePlacement="Left">

            <SplitView.Pane>
                <Grid Padding="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Source (LTR)" FontWeight="SemiBold" Margin="8,4" Opacity="0.7"/>
                    <Border Grid.Row="1" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="4">
                        <WebView2 x:Name="SourceWebView" Source="ms-appx:///Assets/monaco-editor-host.html"/>
                    </Border>
                </Grid>
            </SplitView.Pane>

            <Grid Padding="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Target (RTL)" FontWeight="SemiBold" Margin="8,4" Opacity="0.7"/>
                <Border Grid.Row="1" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="4">
                    <WebView2 x:Name="TargetWebView" Source="ms-appx:///Assets/monaco-editor-host.html"/>
                </Border>
            </Grid>
        </SplitView>

        <!-- Status bar -->
        <Grid Grid.Row="2" Padding="12,4" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,1,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="StatusText" Text="Ready" FontSize="12" Opacity="0.6" Grid.Column="0"/>
            <TextBlock x:Name="RtlStatusText" Text="LTR" FontSize="12" Opacity="0.6" Grid.Column="2"/>
        </Grid>
    </Grid>
</Page>
