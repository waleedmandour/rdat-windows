<Page
    x:Class="RDAT.Copilot.App.Views.ShellPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:RDAT.Copilot.App.Views"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <NavigationView
            x:Name="NavView"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="True"
            PaneDisplayMode="Left"
            OpenPaneLength="280"
            CompactPaneLength="48"
            AutoSuggestBoxPlacement="Top"
            SelectionChanged="NavView_SelectionChanged"
            Loaded="NavView_Loaded">

            <NavigationView.Header>
                <Grid Padding="16,8" ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="RDAT Copilot" Style="{StaticResource TitleTextBlockStyle}" FontSize="20" FontWeight="SemiBold"/>
                        <TextBlock Text="Research-Grade Translation Assistant" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.6" Margin="0,2,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Border x:Name="LinterStatusBorder" Padding="8,4" CornerRadius="4"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderThickness="1" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
                            <TextBlock x:Name="LinterStatusText" Text="Linter: Ready" FontSize="12" Opacity="0.8"/>
                        </Border>
                        <Button x:Name="UndockTmButton" Click="UndockTmButton_Click"
                            ToolTipService.ToolTip="Undock TM Panel">
                            <FontIcon Glyph="&#xE8A4;" FontSize="16"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </NavigationView.Header>

            <NavigationView.MenuItems>
                <NavigationViewItem Content="Translation Workspace" Tag="workspace">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Document"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Translation Memory" Tag="tm">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8F1;" FontSize="16"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Terminology Glossary" Tag="glossary">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Book"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <NavigationView.FooterMenuItems>
                <NavigationViewItem Content="About" Tag="about">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Help"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.FooterMenuItems>

            <NavigationView.AutoSuggestBox>
                <AutoSuggestBox x:Name="SearchBox" QueryIcon="Find" PlaceholderText="Search segments..."/>
            </NavigationView.AutoSuggestBox>

            <Frame x:Name="ContentFrame"/>
        </NavigationView>

        <TeachingTip x:Name="WelcomeTip"
            Title="Welcome to RDAT Copilot"
            Subtitle="Open a .docx file to begin. Press Tab to accept predictions."
            IsOpen="False" 
            CloseButtonContent="Got it"/>
    </Grid>
</Page>
