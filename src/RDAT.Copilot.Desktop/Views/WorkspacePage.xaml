<Page
    x:Class="RDAT.Copilot.Desktop.Views.WorkspacePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:RDAT.Copilot.Desktop.Views"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls">

    <Grid Background="{StaticResource RDATBgPrimaryBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto" x:Name="GrammarPanelRow"/>
        </Grid.RowDefinitions>

        <!-- Tab Bar -->
        <Grid Grid.Row="0" Padding="8,0" Background="{StaticResource RDATTabsBgBrush}"
              BorderBrush="{StaticResource RDATBorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="0" VerticalAlignment="Center">
                <!-- Editor Tab -->
                <Border Background="{StaticResource RDATBgPrimaryBrush}"
                        BorderBrush="{StaticResource RDATBorderBrush}" BorderThickness="0,2,1,0"
                        Padding="12,6" CornerRadius="0">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE8A5;" FontSize="12" Foreground="{StaticResource RDATTealBrush}"/>
                        <TextBlock Text="Translation Workspace" FontSize="12"
                                  Foreground="{StaticResource RDATTextBrush}"/>
                        <Ellipse Width="6" Height="6" Fill="{StaticResource RDATTealBrush}"
                                VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- TM Panel Tab -->
                <Border Padding="12,6" CornerRadius="0">
                    <Button Background="Transparent" BorderThickness="0"
                            Padding="0" Click="TmPanelTab_Click">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE7C3;" FontSize="12"
                                     Foreground="{StaticResource RDATTextMutedBrush}"/>
                            <TextBlock Text="TM Matches" FontSize="12"
                                      Foreground="{StaticResource RDATTextMutedBrush}"/>
                        </StackPanel>
                    </Button>
                </Border>

                <!-- Phase 4: Grammar/Lint Status in Tab Bar -->
                <Border Padding="12,6" CornerRadius="0">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <!-- Grammar status indicator -->
                        <StackPanel Orientation="Horizontal" Spacing="4" Visibility="{x:Bind ViewModel.IsGrammarEnabled, Mode=OneWay}">
                            <FontIcon Glyph="&#xE946;" FontSize="10"
                                     Foreground="{StaticResource RDATTextMutedBrush}"/>
                            <TextBlock Text="{x:Bind ViewModel.GrammarState, Mode=OneWay}"
                                      FontSize="10" Foreground="{StaticResource RDATTextMutedBrush}"/>
                        </StackPanel>

                        <TextBlock Text="│" FontSize="9" Foreground="{StaticResource RDATBorderBrush}"/>

                        <!-- AMTA lint status indicator -->
                        <StackPanel Orientation="Horizontal" Spacing="4" Visibility="{x:Bind ViewModel.IsAmtaLintEnabled, Mode=OneWay}">
                            <FontIcon Glyph="&#xE8F1;" FontSize="10"
                                     Foreground="{StaticResource RDATTextMutedBrush}"/>
                            <TextBlock Text="{x:Bind ViewModel.AmtaState, Mode=OneWay}"
                                      FontSize="10" Foreground="{StaticResource RDATTextMutedBrush}"/>
                        </StackPanel>

                        <!-- Quality score (Phase 4) -->
                        <StackPanel Orientation="Horizontal" Spacing="4"
                                   Visibility="{x:Bind ViewModel.IsGeminiReady, Mode=OneWay}">
                            <TextBlock Text="│" FontSize="9" Foreground="{StaticResource RDATBorderBrush}"/>
                            <FontIcon Glyph="&#xE945;" FontSize="10"
                                     Foreground="{StaticResource RDATTealBrush}"/>
                            <TextBlock Text="{x:Bind ViewModel.QualityScore, Mode=OneWay}"
                                      FontSize="10" Foreground="{StaticResource RDATTealBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Settings Tab -->
                <Border Padding="12,6" CornerRadius="0">
                    <Button Background="Transparent" BorderThickness="0"
                            Padding="0" Click="SettingsTab_Click">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE713;" FontSize="12"
                                     Foreground="{StaticResource RDATTextMutedBrush}"/>
                            <TextBlock Text="Settings" FontSize="12"
                                      Foreground="{StaticResource RDATTextMutedBrush}"/>
                        </StackPanel>
                    </Button>
                </Border>
            </StackPanel>
        </Grid>

        <!-- Main Content Area -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="400"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="320" MinWidth="240" x:Name="TmPanelColumn"/>
            </Grid.ColumnDefinitions>

            <!-- Split-Pane Editor Area -->
            <Grid Grid.Column="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="38*" MinWidth="200"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="62*" MinWidth="300"/>
                </Grid.ColumnDefinitions>

                <!-- SOURCE Pane -->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="28"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Source Pane Header -->
                    <Border Grid.Row="0" Padding="12,0" Background="{StaticResource RDATTabsBgBrush}"
                           BorderBrush="{StaticResource RDATBorderBrush}" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                <Ellipse Width="6" Height="6" Fill="#f59e0b" Opacity="0.7"/>
                                <TextBlock Text="SOURCE" FontSize="11"
                                          Foreground="{StaticResource RDATTextMutedBrush}"
                                          FontWeight="SemiBold"/>
                                <Border Background="{StaticResource RDATBgTertiaryBrush}"
                                       BorderBrush="{StaticResource RDATBorderBrush}"
                                       Padding="6,2" CornerRadius="3">
                                    <TextBlock Text="English" FontSize="10"
                                             Foreground="{StaticResource RDATTextMutedBrush}"/>
                                </Border>
                            </StackPanel>

                            <Button Grid.Column="2" Content="✎" FontSize="11"
                                   Background="Transparent" BorderThickness="0"
                                   Padding="4" Click="EditSource_Click"
                                   ToolTipService.ToolTip="Edit source text">
                                <Button.Foreground>
                                    <SolidColorBrush Color="{StaticResource RDATTextDim}"/>
                                </Button.Foreground>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Source WebView2 (Monaco) -->
                    <Grid Grid.Row="1">
                        <WebView2 x:Name="SourceWebView"
                                 Source="ms-appx:///Assets/Monaco/editor-source.html"
                                 DefaultBackgroundColor="#1e1e2e"/>
                    </Grid>
                </Grid>

                <!-- Resize Handle -->
                <controls:GridSplitter Grid.Column="1"
                                       Width="6" HorizontalAlignment="Center"
                                       Background="Transparent"
                                       ResizeDirection="Columns"
                                       CursorBehavior="ChangeOnSplitterHover">
                    <controls:GridSplitter.RenderTransform>
                        <TranslateTransform X="-3"/>
                    </controls:GridSplitter.RenderTransform>
                </controls:GridSplitter>

                <!-- TARGET Pane -->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="28"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Target Pane Header -->
                    <Border Grid.Row="0" Padding="12,0" Background="{StaticResource RDATTabsBgBrush}"
                           BorderBrush="{StaticResource RDATBorderBrush}" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                <Ellipse Width="6" Height="6" Fill="{StaticResource RDATTealBrush}"/>
                                <TextBlock Text="TARGET" FontSize="11"
                                          Foreground="{StaticResource RDATTextBrush}"
                                          FontWeight="SemiBold"/>
                                <Border Background="#0d948820" BorderBrush="#14b8a630"
                                       Padding="6,2" CornerRadius="3">
                                    <TextBlock Text="Arabic" FontSize="10"
                                             Foreground="#5eead4"/>
                                </Border>
                            </StackPanel>

                            <!-- GTR Match Indicator (Phase 2) -->
                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4">
                                <!-- Phase 4: Grammar Error/Warning Counts -->
                                <StackPanel Orientation="Horizontal" Spacing="3"
                                           Visibility="{x:Bind ViewModel.IsGrammarEnabled, Mode=OneWay}">
                                    <Border Background="#ef444420" BorderBrush="#ef444430"
                                           Padding="4,1" CornerRadius="3"
                                           Visibility="{x:Bind ViewModel.GrammarErrorCount, Mode=OneWay, Converter={StaticResource IntToVisibilityConverter}}">
                                        <TextBlock Text="{x:Bind ViewModel.GrammarErrorCount, Mode=OneWay}"
                                                  FontSize="10" Foreground="#fca5a5"/>
                                    </Border>
                                    <Border Background="#f59e0b20" BorderBrush="#f59e0b30"
                                           Padding="4,1" CornerRadius="3"
                                           Visibility="{x:Bind ViewModel.GrammarWarningCount, Mode=OneWay, Converter={StaticResource IntToVisibilityConverter}}">
                                        <TextBlock Text="{x:Bind ViewModel.GrammarWarningCount, Mode=OneWay}"
                                                  FontSize="10" Foreground="#fcd34d"/>
                                    </Border>
                                </StackPanel>

                                <!-- Phase 4: AMTA Issue Count -->
                                <Border Background="#8b5cf620" BorderBrush="#8b5cf630"
                                       Padding="4,1" CornerRadius="3"
                                       Visibility="{x:Bind ViewModel.AmtaIssueCount, Mode=OneWay, Converter={StaticResource IntToVisibilityConverter}}">
                                    <TextBlock Text="{x:Bind ViewModel.AmtaIssueCount, Mode=OneWay}"
                                              FontSize="10" Foreground="#c4b5fd"/>
                                </Border>

                                <StackPanel Orientation="Horizontal" Spacing="4"
                                           Visibility="{x:Bind ViewModel.HasRagMatch, Mode=OneWay}">
                                    <FontIcon Glyph="&#xE945;" FontSize="10" Foreground="{StaticResource RDATTealBrush}"/>
                                    <TextBlock Text="{x:Bind ViewModel.RagDetail, Mode=OneWay}"
                                              FontSize="10" Foreground="{StaticResource RDATTealBrush}"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Target WebView2 (Monaco) -->
                    <Grid Grid.Row="1">
                        <WebView2 x:Name="TargetWebView"
                                 Source="ms-appx:///Assets/Monaco/editor-target.html"
                                 DefaultBackgroundColor="#1e1e2e"/>
                    </Grid>
                </Grid>
            </Grid>

            <!-- TM Panel Resize Handle -->
            <controls:GridSplitter Grid.Column="1" x:Name="TmPanelSplitter"
                                   Width="4" HorizontalAlignment="Center"
                                   Background="Transparent"
                                   ResizeDirection="Columns"
                                   CursorBehavior="ChangeOnSplitterHover"
                                   Visibility="{x:Bind TmPanelViewModel.IsPanelOpen, Mode=OneWay}">
                <controls:GridSplitter.RenderTransform>
                    <TranslateTransform X="-2"/>
                </controls:GridSplitter.RenderTransform>
            </controls:GridSplitter>

            <!-- Phase 2: TM (Translation Memory) Panel -->
            <Grid Grid.Column="2" x:Name="TmPanelGrid"
                  Visibility="{x:Bind TmPanelViewModel.IsPanelOpen, Mode=OneWay}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- TM Panel Background -->
                <Border Grid.RowSpan="5" Background="{StaticResource RDATBgSecondaryBrush}"
                       BorderBrush="{StaticResource RDATBorderBrush}" BorderThickness="1,0,0,0"/>

                <!-- TM Panel Header -->
                <Border Grid.Row="0" Padding="12,8"
                       BorderBrush="{StaticResource RDATBorderBrush}" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <FontIcon Glyph="&#xE7C3;" FontSize="14" Foreground="{StaticResource RDATTealBrush}"/>
                            <TextBlock Text="Translation Memory" FontSize="12"
                                      Foreground="{StaticResource RDATTextBrush}"
                                      FontWeight="SemiBold"/>
                            <TextBlock Text="قاعدة الترجمة" FontSize="9"
                                      Foreground="{StaticResource RDATTextDimBrush}"
                                      Margin="2,0,0,0"/>
                        </StackPanel>

                        <Button Grid.Column="2" Background="Transparent" BorderThickness="0"
                               Padding="4" Click="CloseTmPanel_Click"
                               ToolTipService.ToolTip="Close panel">
                            <FontIcon Glyph="&#xE711;" FontSize="12"
                                     Foreground="{StaticResource RDATTextMutedBrush}"/>
                        </Button>
                    </Grid>
                </Border>

                <!-- TM Stats -->
                <Border Grid.Row="1" Padding="12,6" Margin="0">
                    <StackPanel Spacing="4">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="{x:Bind TmPanelViewModel.StatusMessage, Mode=OneWay}"
                                      FontSize="11" Foreground="{StaticResource RDATTextMutedBrush}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="│" FontSize="10" Foreground="{StaticResource RDATBorderBrush}"/>
                            <TextBlock Text="{x:Bind TmPanelViewModel.RAGStateDisplay, Mode=OneWay}"
                                      FontSize="10" Foreground="{StaticResource RDATTextDimBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- TM Search Bar -->
                <Border Grid.Row="2" Padding="8,4">
                    <AutoSuggestBox x:Name="TmSearchBox"
                                   PlaceholderText="Search TM..."
                                   QueryIcon="&#xE721;"
                                   Text="{x:Bind TmPanelViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                   QuerySubmitted="TmSearch_QuerySubmitted"
                                   KeyDown="TmSearch_KeyDown"/>
                </Border>

                <!-- TM Search Results -->
                <ScrollViewer Grid.Row="3" Padding="8,0" VerticalScrollBarVisibility="Auto">
                    <ListView x:Name="TmResultsList"
                             ItemsSource="{x:Bind TmPanelViewModel.SearchResults}"
                             SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8" Margin="0,0,0,4"
                                       Background="{StaticResource RDATBgTertiaryBrush}"
                                       BorderBrush="{StaticResource RDATBorderBrush}"
                                       BorderThickness="1" CornerRadius="4">
                                    <StackPanel Spacing="4">
                                        <!-- Source -->
                                        <TextBlock Text="{Binding Entry.SourceText}"
                                                  FontSize="11" TextTrimming="CharacterEllipsis"
                                                  MaxLines="2" Foreground="{StaticResource RDATTextMutedBrush}"/>
                                        <!-- Arrow -->
                                        <FontIcon Glyph="&#xE72A;" FontSize="9"
                                                 Foreground="{StaticResource RDATTextDimBrush}"/>
                                        <!-- Target -->
                                        <TextBlock Text="{Binding Entry.TargetText}"
                                                  FontSize="12" TextTrimming="CharacterEllipsis"
                                                  MaxLines="3" Foreground="{StaticResource RDATTextBrush}"
                                                  FontWeight="SemiBold"
                                                  TextWrapping="Wrap"/>
                                        <!-- Score -->
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <TextBlock Text="{Binding Score, Converter={StaticResource ScoreToPercentConverter}}"
                                                      FontSize="10" Foreground="{StaticResource RDATTealBrush}"/>
                                            <TextBlock Text="match" FontSize="10"
                                                      Foreground="{StaticResource RDATTextDimBrush}"/>
                                            <TextBlock Text="{Binding SearchMs, Converter={StaticResource MsFormatter}}"
                                                      FontSize="9" Foreground="{StaticResource RDATTextDimBrush}"
                                                      Margin="8,0,0,0"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </ScrollViewer>

                <!-- TM Import Section -->
                <Border Grid.Row="4" Padding="8,6"
                       BorderBrush="{StaticResource RDATBorderBrush}" BorderThickness="0,1,0,0">
                    <StackPanel Spacing="6">
                        <!-- Progress bar (visible during import) -->
                        <ProgressBar x:Name="TmImportProgress"
                                    Value="{x:Bind TmPanelViewModel.ImportPercent, Mode=OneWay}"
                                    Visibility="{x:Bind TmPanelViewModel.IsImporting, Mode=OneWay}"
                                    ShowError="False" ShowPaused="False"/>
                        <TextBlock Text="{x:Bind TmPanelViewModel.ImportProgress, Mode=OneWay}"
                                  FontSize="10" Foreground="{StaticResource RDATTextMutedBrush}"
                                  Visibility="{x:Bind TmPanelViewModel.IsImporting, Mode=OneWay}"/>

                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Button Content="&#xE8E5;" Click="ImportTm_Click"
                                   ToolTipService.ToolTip="Import TM file (CSV, TMX, TSV)"
                                   Padding="6" CornerRadius="4"
                                   IsEnabled="{x:Bind TmPanelViewModel.IsImporting, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}">
                                <Button.Foreground>
                                    <SolidColorBrush Color="{StaticResource RDATTextMuted}"/>
                                </Button.Foreground>
                            </Button>
                            <Button Content="&#xE72C;" Click="RefreshTm_Click"
                                   ToolTipService.ToolTip="Refresh TM stats"
                                   Padding="6" CornerRadius="4">
                                <Button.Foreground>
                                    <SolidColorBrush Color="{StaticResource RDATTextMuted}"/>
                                </Button.Foreground>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- Phase 4: Grammar/Lint Error List Panel (bottom) -->
        <Border Grid.Row="2" Background="{StaticResource RDATBgSecondaryBrush}"
                BorderBrush="{StaticResource RDATBorderBrush}" BorderThickness="0,1,0,0"
                Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="24"/>
                    <RowDefinition Height="Auto" MaxHeight="180"/>
                </Grid.RowDefinitions>

                <!-- Error List Header -->
                <Border Grid.Row="0" Padding="12,0"
                       BorderBrush="{StaticResource RDATBorderBrush}" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <FontIcon Glyph="&#xE946;" FontSize="11"
                                     Foreground="{StaticResource RDATTextMutedBrush}"/>
                            <TextBlock Text="Issues — المشكلات" FontSize="11"
                                      Foreground="{StaticResource RDATTextMutedBrush}"
                                      FontWeight="SemiBold"/>

                            <!-- Grammar errors -->
                            <Border Background="#ef444420" Padding="4,1" CornerRadius="3">
                                <TextBlock FontSize="9" Foreground="#fca5a5">
                                    <Run Text="Grammar: "/>
                                    <Run Text="{x:Bind ViewModel.GrammarErrorCount, Mode=OneWay}"/>
                                </TextBlock>
                            </Border>

                            <!-- Grammar warnings -->
                            <Border Background="#f59e0b20" Padding="4,1" CornerRadius="3">
                                <TextBlock FontSize="9" Foreground="#fcd34d">
                                    <Run Text="Style: "/>
                                    <Run Text="{x:Bind ViewModel.GrammarWarningCount, Mode=OneWay}"/>
                                </TextBlock>
                            </Border>

                            <!-- AMTA lint issues -->
                            <Border Background="#8b5cf620" Padding="4,1" CornerRadius="3">
                                <TextBlock FontSize="9" Foreground="#c4b5fd">
                                    <Run Text="Terms: "/>
                                    <Run Text="{x:Bind ViewModel.AmtaIssueCount, Mode=OneWay}"/>
                                </TextBlock>
                            </Border>
                        </StackPanel>

                        <!-- Quality estimation button (Phase 4: Gemini) -->
                        <Button Grid.Column="2" Background="Transparent" BorderThickness="0"
                               Padding="4" Click="RunQualityCheck_Click"
                               ToolTipService.ToolTip="Run quality estimation (Gemini)"
                               Visibility="{x:Bind ViewModel.IsGeminiReady, Mode=OneWay}">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <FontIcon Glyph="&#xE945;" FontSize="10"
                                         Foreground="{StaticResource RDATTealBrush}"/>
                                <TextBlock Text="Estimate Quality" FontSize="10"
                                          Foreground="{StaticResource RDATTealBrush}"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <!-- Error List Content -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                             Padding="4,0">
                    <ListView ItemsSource="{x:Bind ViewModel.GrammarIssues}"
                             SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8,4" Margin="0,1" CornerRadius="3"
                                       Background="{StaticResource RDATBgTertiaryBrush}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Error type icon -->
                                        <FontIcon Grid.Column="0" Margin="0,0,8,0"
                                                 Glyph="{Binding Type, Converter={StaticResource GrammarTypeToIconConverter}}"
                                                 FontSize="12"
                                                 Foreground="{Binding Type, Converter={StaticResource GrammarTypeToColorConverter}}"/>

                                        <!-- Error message -->
                                        <StackPanel Grid.Column="1" Spacing="2">
                                            <TextBlock Text="{Binding Message}"
                                                      FontSize="11" Foreground="{StaticResource RDATTextBrush}"
                                                      TextTrimming="CharacterEllipsis"/>
                                            <TextBlock FontSize="10" Foreground="{StaticResource RDATTextMutedBrush}">
                                                <Run Text="Line "/>
                                                <Run Text="{Binding StartLineNumber}"/>
                                                <Run Text=" · Suggestion: "/>
                                                <Run Text="{Binding Suggestion}"
                                                     Foreground="{StaticResource RDATTealBrush}"/>
                                            </TextBlock>
                                        </StackPanel>

                                        <!-- Quick fix button -->
                                        <Button Grid.Column="2" Background="Transparent" BorderThickness="0"
                                               Padding="4" Click="AcceptGrammarFix_Click"
                                               ToolTipService.ToolTip="Accept suggestion">
                                            <FontIcon Glyph="&#xE8FB;" FontSize="10"
                                                     Foreground="{StaticResource RDATTextMutedBrush}"/>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </ScrollViewer>

                <!-- Quality Feedback (shown after estimation) -->
                <Border Grid.Row="1" Padding="12" Visibility="{x:Bind ViewModel.QualityFeedback, Mode=OneWay, Converter={StaticResource StringToVisibilityConverter}}">
                    <TextBlock Text="{x:Bind ViewModel.QualityFeedback, Mode=OneWay}"
                              FontSize="11" Foreground="{StaticResource RDATTealBrush}"
                              TextWrapping="Wrap"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Page>
