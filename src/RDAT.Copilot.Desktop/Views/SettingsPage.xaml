<Page
    x:Class="RDAT.Copilot.Desktop.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:RDAT.Copilot.Desktop.Converters">

    <Page.Resources>
        <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <converters:LanguageDirectionToBoolConverter x:Key="LangDirConverter"/>
    </Page.Resources>

    <Grid Background="{StaticResource RDATBgPrimaryBrush}" Padding="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="8" Margin="0,0,0,24">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <FontIcon Glyph="&#xE713;" FontSize="20" Foreground="{StaticResource RDATTealBrush}"/>
                <TextBlock Text="Settings — الإعدادات" FontSize="20"
                          Foreground="{StaticResource RDATTextBrush}"
                          FontWeight="SemiBold"/>
            </StackPanel>
            <TextBlock Text="Configure RDAT Copilot preferences and API keys."
                      FontSize="13" Foreground="{StaticResource RDATTextMutedBrush}"/>
        </StackPanel>

        <!-- Settings Sections -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="16" MaxWidth="700">

                <!-- General Section -->
                <Border Background="{StaticResource RDATBgSecondaryBrush}"
                       BorderBrush="{StaticResource RDATBorderBrush}"
                       CornerRadius="8" Padding="20">
                    <StackPanel Spacing="12">
                        <TextBlock Text="General — عام" FontSize="14"
                                  Foreground="{StaticResource RDATTextBrush}"
                                  FontWeight="SemiBold"/>

                        <StackPanel Spacing="8">
                            <TextBlock Text="Language Direction" FontSize="12"
                                      Foreground="{StaticResource RDATTextMutedBrush}"/>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <RadioButton Content="English → Arabic (إنجليزية → عربية)"
                                           IsChecked="{x:Bind ViewModel.LanguageDirection, Mode=TwoWay, Converter={StaticResource LangDirConverter}, ConverterParameter=EnToAr}"
                                           GroupName="LangDir"
                                           Foreground="{StaticResource RDATTextBrush}"/>
                                <RadioButton Content="Arabic → English (عربية → إنجليزية)"
                                           IsChecked="{x:Bind ViewModel.LanguageDirection, Mode=TwoWay, Converter={StaticResource LangDirConverter}, ConverterParameter=ArToEn}"
                                           GroupName="LangDir"
                                           Foreground="{StaticResource RDATTextBrush}"/>
                            </StackPanel>
                            <TextBlock Text="Changing direction swaps source/target panes and adjusts text layout."
                                      FontSize="10" Foreground="{StaticResource RDATTextDimBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- SaveStatus InfoBar (shown when status message is set) -->
                <InfoBar
                    IsOpen="{x:Bind ViewModel.SaveStatus, Mode=OneWay, Converter={StaticResource StringToVisibilityConverter}}"
                    Severity="Informational"
                    Title="Status"
                    Message="{x:Bind ViewModel.SaveStatus, Mode=OneWay}"
                    IsClosable="True" Margin="0,0,0,4"/>

                <!-- Phase 2: Translation Memory Section -->
                <Border Background="{StaticResource RDATBgSecondaryBrush}"
                       BorderBrush="{StaticResource RDATBorderBrush}"
                       CornerRadius="8" Padding="20">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE7C3;" FontSize="14" Foreground="{StaticResource RDATTealBrush}"/>
                            <TextBlock Text="Translation Memory — قاعدة الترجمة" FontSize="14"
                                      Foreground="{StaticResource RDATTextBrush}"
                                      FontWeight="SemiBold"/>
                        </StackPanel>

                        <TextBlock Text="Configure the local Translation Memory database and embedding model. TM matches appear as GTR (Guaranteed Translation Result) ghost text in the target editor."
                                  FontSize="12" Foreground="{StaticResource RDATTextMutedBrush}"
                                  TextWrapping="Wrap"/>

                        <!-- Embedding Model Path -->
                        <StackPanel Spacing="6">
                            <TextBlock Text="Embedding Model Path" FontSize="12"
                                      Foreground="{StaticResource RDATTextMutedBrush}"/>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBox x:Name="EmbeddingModelPathBox"
                                        PlaceholderText="C:\Models\paraphrase-multilingual-MiniLM-L12-v2"
                                        Text="{x:Bind ViewModel.EmbeddingModelPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        IsReadOnly="False" MinWidth="350"
                                        Background="{StaticResource RDATBgTertiaryBrush}"/>
                                <Button Content="&#xE8E5;" Click="BrowseModel_Click"
                                       ToolTipService.ToolTip="Browse for model folder"
                                       Padding="8" CornerRadius="4"
                                       Background="{StaticResource RDATBgTertiaryBrush}"
                                       BorderBrush="{StaticResource RDATBorderBrush}">
                                    <FontIcon Glyph="&#xE8DA;" FontSize="12"
                                             Foreground="{StaticResource RDATTextMutedBrush}"/>
                                </Button>
                            </StackPanel>
                            <TextBlock Text="ONNX model: paraphrase-multilingual-MiniLM-L12-v2 (384-dim)"
                                      FontSize="10" Foreground="{StaticResource RDATTextDimBrush}"/>
                        </StackPanel>

                        <!-- TM Database Path -->
                        <StackPanel Spacing="6">
                            <TextBlock Text="TM Database Path" FontSize="12"
                                      Foreground="{StaticResource RDATTextMutedBrush}"/>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBox x:Name="TmDbPathBox"
                                        PlaceholderText="%LOCALAPPDATA%\RDAT\TM\Database"
                                        Text="{x:Bind ViewModel.TmDbPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        MinWidth="350"
                                        Background="{StaticResource RDATBgTertiaryBrush}"/>
                                <Button Content="&#xE8E5;" Click="BrowseDb_Click"
                                       ToolTipService.ToolTip="Browse for database folder"
                                       Padding="8" CornerRadius="4"
                                       Background="{StaticResource RDATBgTertiaryBrush}"
                                       BorderBrush="{StaticResource RDATBorderBrush}">
                                    <FontIcon Glyph="&#xE8DA;" FontSize="12"
                                             Foreground="{StaticResource RDATTextMutedBrush}"/>
                                </Button>
                            </StackPanel>
                            <TextBlock Text="LanceDB disk-backed database (supports 10M+ entries)"
                                      FontSize="10" Foreground="{StaticResource RDATTextDimBrush}"/>
                        </StackPanel>

                        <!-- RAG Pipeline Status -->
                        <Border Background="{StaticResource RDATBgPrimaryBrush}"
                               BorderBrush="{StaticResource RDATBorderBrush}"
                               Padding="12" CornerRadius="4">
                            <StackPanel Spacing="6">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="RAG Pipeline Status" FontSize="12"
                                              Foreground="{StaticResource RDATTextMutedBrush}"
                                              FontWeight="SemiBold"/>
                                    <Ellipse Width="6" Height="6">
                                        <Ellipse.Fill>
                                            <SolidColorBrush Color="{StaticResource RDATTealPrimary}"/>
                                        </Ellipse.Fill>
                                    </Ellipse>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <TextBlock Text="State:" FontSize="11"
                                              Foreground="{StaticResource RDATTextDimBrush}"/>
                                    <TextBlock Text="{x:Bind ViewModel.RagPipelineState, Mode=OneWay}"
                                              FontSize="11"
                                              Foreground="{StaticResource RDATTextBrush}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <TextBlock Text="TM Entries:" FontSize="11"
                                              Foreground="{StaticResource RDATTextDimBrush}"/>
                                    <TextBlock Text="{x:Bind ViewModel.TmEntryCount, Mode=OneWay}"
                                              FontSize="11"
                                              Foreground="{StaticResource RDATTextBrush}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Initialize / Reinitialize RAG -->
                        <Button Content="Initialize RAG Pipeline" Click="InitRag_Click"
                               Style="{StaticResource AccentButtonStyle}"
                               Padding="20,8" CornerRadius="4"/>
                    </StackPanel>
                </Border>

                <!-- Phase 5: Document Import Section -->
                <Border Background="{StaticResource RDATBgSecondaryBrush}"
                       BorderBrush="{StaticResource RDATBorderBrush}"
                       CornerRadius="8" Padding="20">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE8A5;" FontSize="14" Foreground="#94e2d5"/>
                            <TextBlock Text="Document Import — استيراد المستندات" FontSize="14"
                                      Foreground="{StaticResource RDATTextBrush}"
                                      FontWeight="SemiBold"/>
                        </StackPanel>

                        <TextBlock Text="Import .docx documents for paragraph-by-paragraph translation. Each paragraph becomes a separate line in the source editor, enabling segment-level alignment with the target editor."
                                  FontSize="12" Foreground="{StaticResource RDATTextMutedBrush}"
                                  TextWrapping="Wrap"/>

                        <!-- Supported Formats -->
                        <Border Background="{StaticResource RDATBgPrimaryBrush}"
                               BorderBrush="{StaticResource RDATBorderBrush}"
                               Padding="12" CornerRadius="4">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Supported Formats" FontSize="11"
                                          Foreground="{StaticResource RDATTextDimBrush}"
                                          FontWeight="SemiBold"/>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="Format:" FontSize="10" Foreground="{StaticResource RDATTextDimBrush}"/>
                                    <TextBlock Text=".docx (Microsoft Word 2007+)" FontSize="10" Foreground="{StaticResource RDATTextMutedBrush}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="Alignment:" FontSize="10" Foreground="{StaticResource RDATTextDimBrush}"/>
                                    <TextBlock Text="Paragraph-by-paragraph (one paragraph per line)" FontSize="10" Foreground="{StaticResource RDATTextMutedBrush}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="Encoding:" FontSize="10" Foreground="{StaticResource RDATTextDimBrush}"/>
                                    <TextBlock Text="UTF-8 with full Arabic/RTL text support" FontSize="10" Foreground="{StaticResource RDATTextMutedBrush}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="Styles:" FontSize="10" Foreground="{StaticResource RDATTextDimBrush}"/>
                                    <TextBlock Text="Preserves paragraph styles (Heading1, Normal, Quote, etc.)" FontSize="10" Foreground="{StaticResource RDATTextMutedBrush}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Import Behavior Info -->
                        <Border Background="{StaticResource RDATBgPrimaryBrush}"
                               BorderBrush="{StaticResource RDATBorderBrush}"
                               Padding="12" CornerRadius="4">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Import Behavior" FontSize="11"
                                          Foreground="{StaticResource RDATTextDimBrush}"
                                          FontWeight="SemiBold"/>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="•" FontSize="10" Foreground="{StaticResource RDATTextMutedBrush}"/>
                                    <TextBlock Text="Empty paragraphs are preserved for alignment fidelity" FontSize="10" Foreground="{StaticResource RDATTextMutedBrush}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="•" FontSize="10" Foreground="{StaticResource RDATTextMutedBrush}"/>
                                    <TextBlock Text="Line breaks within paragraphs map to multiple editor lines" FontSize="10" Foreground="{StaticResource RDATTextMutedBrush}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="•" FontSize="10" Foreground="{StaticResource RDATTextMutedBrush}"/>
                                    <TextBlock Text="Headings, lists, and other styles are detected and tagged" FontSize="10" Foreground="{StaticResource RDATTextMutedBrush}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="•" FontSize="10" Foreground="{StaticResource RDATTextMutedBrush}"/>
                                    <TextBlock Text="Import is cancellable — Ctrl+click the progress indicator to stop" FontSize="10" Foreground="{StaticResource RDATTextMutedBrush}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Phase 4: Gemini Cloud AI Section -->
                <Border Background="{StaticResource RDATBgSecondaryBrush}"
                       BorderBrush="{StaticResource RDATBorderBrush}"
                       CornerRadius="8" Padding="20">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE945;" FontSize="14" Foreground="#a78bfa"/>
                            <TextBlock Text="Gemini Cloud AI — ذكاء جوجل سحابي" FontSize="14"
                                      Foreground="{StaticResource RDATTextBrush}"
                                      FontWeight="SemiBold"/>
                        </StackPanel>

                        <TextBlock Text="Connect Google Gemini 2.0 Flash for enhanced grammar checking, quality estimation, and style analysis. Your API key is stored securely in Windows Credential Locker — it never leaves your device."
                                  FontSize="12" Foreground="{StaticResource RDATTextMutedBrush}"
                                  TextWrapping="Wrap"/>

                        <!-- API Key Input -->
                        <StackPanel Spacing="6">
                            <TextBlock Text="Gemini API Key (BYOK)" FontSize="12"
                                      Foreground="{StaticResource RDATTextMutedBrush}"/>
                            <PasswordBox x:Name="GeminiApiKeyBox"
                                        PlaceholderText="Enter your Gemini API key..."
                                        CornerRadius="4"
                                        Background="{StaticResource RDATBgTertiaryBrush}"/>
                            <TextBlock Text="Get your key from Google AI Studio (aistudio.google.com). Free tier: 15 RPM."
                                      FontSize="10" Foreground="{StaticResource RDATTextDimBrush}"/>
                        </StackPanel>

                        <!-- Gemini Status -->
                        <Border Background="{StaticResource RDATBgPrimaryBrush}"
                               BorderBrush="{StaticResource RDATBorderBrush}"
                               Padding="12" CornerRadius="4">
                            <StackPanel Spacing="6">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="Gemini Status" FontSize="12"
                                              Foreground="{StaticResource RDATTextMutedBrush}"
                                              FontWeight="SemiBold"/>
                                    <Ellipse Width="6" Height="6">
                                        <Ellipse.Fill>
                                            <SolidColorBrush Color="#a78bfa"/>
                                        </Ellipse.Fill>
                                    </Ellipse>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <TextBlock Text="State:" FontSize="11"
                                              Foreground="{StaticResource RDATTextDimBrush}"/>
                                    <TextBlock Text="{x:Bind ViewModel.GeminiStateDisplay, Mode=OneWay}"
                                              FontSize="11"
                                              Foreground="{StaticResource RDATTextBrush}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Save/Validate/Remove Buttons -->
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="Save &amp; Validate" Click="SaveGeminiKey_Click"
                                   Style="{StaticResource AccentButtonStyle}"
                                   Padding="20,8" CornerRadius="4"
                                   IsEnabled="{x:Bind ViewModel.IsSaving, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"/>
                            <Button Content="Validate" Click="ValidateGeminiKey_Click"
                                   Background="{StaticResource RDATBgTertiaryBrush}"
                                   BorderBrush="{StaticResource RDATBorderBrush}"
                                   Padding="20,8" CornerRadius="4"/>
                            <Button Content="Remove Key" Click="RemoveGeminiKey_Click"
                                   Background="Transparent"
                                   BorderBrush="#ef444430"
                                   Padding="20,8" CornerRadius="4">
                                <Button.Foreground>
                                    <SolidColorBrush Color="#ef4444"/>
                                </Button.Foreground>
                            </Button>
                        </StackPanel>

                        <!-- Cloud Features Info -->
                        <Border Background="{StaticResource RDATBgPrimaryBrush}"
                               BorderBrush="{StaticResource RDATBorderBrush}"
                               Padding="12" CornerRadius="4">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Cloud Features" FontSize="11"
                                          Foreground="{StaticResource RDATTextDimBrush}"
                                          FontWeight="SemiBold"/>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="Grammar:" FontSize="10" Foreground="{StaticResource RDATTextDimBrush}"/>
                                    <TextBlock Text="Enhanced Arabic morphological analysis" FontSize="10" Foreground="{StaticResource RDATTextMutedBrush}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="Quality:" FontSize="10" Foreground="{StaticResource RDATTextDimBrush}"/>
                                    <TextBlock Text="Score: accuracy, fluency, style, terminology (0-100)" FontSize="10" Foreground="{StaticResource RDATTextMutedBrush}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="Rewrite:" FontSize="10" Foreground="{StaticResource RDATTextDimBrush}"/>
                                    <TextBlock Text="Style normalization and tone adjustment" FontSize="10" Foreground="{StaticResource RDATTextMutedBrush}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Phase 4: AMTA Terminology Glossary Section -->
                <Border Background="{StaticResource RDATBgSecondaryBrush}"
                       BorderBrush="{StaticResource RDATBorderBrush}"
                       CornerRadius="8" Padding="20">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE8F1;" FontSize="14" Foreground="#818cf8"/>
                            <TextBlock Text="AMTA Terminology Glossary — قاموس المصطلحات" FontSize="14"
                                      Foreground="{StaticResource RDATTextBrush}"
                                      FontWeight="SemiBold"/>
                        </StackPanel>

                        <TextBlock Text="Load a terminology glossary to enforce consistent translation of domain-specific terms. The AMTA linter flags missing, inconsistent, or untranslated terms with severity levels."
                                  FontSize="12" Foreground="{StaticResource RDATTextMutedBrush}"
                                  TextWrapping="Wrap"/>

                        <!-- Glossary Path -->
                        <StackPanel Spacing="6">
                            <TextBlock Text="Glossary File Path" FontSize="12"
                                      Foreground="{StaticResource RDATTextMutedBrush}"/>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBox x:Name="GlossaryPathBox"
                                        PlaceholderText="C:\Glossaries\legal-terms.csv"
                                        Text="{x:Bind ViewModel.GlossaryPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        MinWidth="350"
                                        Background="{StaticResource RDATBgTertiaryBrush}"/>
                                <Button Content="&#xE8E5;" Click="BrowseGlossary_Click"
                                       ToolTipService.ToolTip="Browse for glossary file"
                                       Padding="8" CornerRadius="4"
                                       Background="{StaticResource RDATBgTertiaryBrush}"
                                       BorderBrush="{StaticResource RDATBorderBrush}">
                                    <FontIcon Glyph="&#xE8DA;" FontSize="12"
                                             Foreground="{StaticResource RDATTextMutedBrush}"/>
                                </Button>
                            </StackPanel>
                            <TextBlock Text="Supported: CSV, JSON, TSV — CSV: source_term,target_term,domain,notes"
                                      FontSize="10" Foreground="{StaticResource RDATTextDimBrush}"/>
                        </StackPanel>

                        <!-- AMTA Linter Status -->
                        <Border Background="{StaticResource RDATBgPrimaryBrush}"
                               BorderBrush="{StaticResource RDATBorderBrush}"
                               Padding="12" CornerRadius="4">
                            <StackPanel Spacing="6">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="AMTA Linter Status" FontSize="12"
                                              Foreground="{StaticResource RDATTextMutedBrush}"
                                              FontWeight="SemiBold"/>
                                    <Ellipse Width="6" Height="6">
                                        <Ellipse.Fill>
                                            <SolidColorBrush Color="#818cf8"/>
                                        </Ellipse.Fill>
                                    </Ellipse>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <TextBlock Text="State:" FontSize="11"
                                              Foreground="{StaticResource RDATTextDimBrush}"/>
                                    <TextBlock Text="{x:Bind ViewModel.AmtaLinterState, Mode=OneWay}"
                                              FontSize="11"
                                              Foreground="{StaticResource RDATTextBrush}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <TextBlock Text="Terms:" FontSize="11"
                                              Foreground="{StaticResource RDATTextDimBrush}"/>
                                    <TextBlock Text="{x:Bind ViewModel.AmtaTermCountDisplay, Mode=OneWay}"
                                              FontSize="11"
                                              Foreground="{StaticResource RDATTextBrush}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Load Glossary Button -->
                        <Button Content="Load Glossary" Click="LoadGlossary_Click"
                               Style="{StaticResource AccentButtonStyle}"
                               Padding="20,8" CornerRadius="4"/>
                    </StackPanel>
                </Border>

                <!-- Phase 4: Grammar/Lint Toggles Section -->
                <Border Background="{StaticResource RDATBgSecondaryBrush}"
                       BorderBrush="{StaticResource RDATBorderBrush}"
                       CornerRadius="8" Padding="20">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE946;" FontSize="14" Foreground="{StaticResource RDATTealBrush}"/>
                            <TextBlock Text="Grammar &amp; Lint — التدقيق النحوي" FontSize="14"
                                      Foreground="{StaticResource RDATTextBrush}"
                                      FontWeight="SemiBold"/>
                        </StackPanel>

                        <TextBlock Text="Configure grammar checking and terminology linting behavior. Local grammar uses the ONNX LLM; Gemini grammar provides enhanced analysis for complex Arabic morphological issues."
                                  FontSize="12" Foreground="{StaticResource RDATTextMutedBrush}"
                                  TextWrapping="Wrap"/>

                        <!-- Toggle: Local Grammar Checker -->
                        <ToggleSwitch
                                     IsOn="{x:Bind ViewModel.IsGrammarEnabled, Mode=TwoWay}"
                                     OnContent="Enabled" OffContent="Disabled">
                            <ToggleSwitch.Header>
                                <TextBlock Text="Local Grammar Checker (ONNX LLM)" FontSize="12"
                                          Foreground="{StaticResource RDATTextBrush}"/>
                            </ToggleSwitch.Header>
                        </ToggleSwitch>
                        <TextBlock Text="Checks grammar, spelling, punctuation, and style using the local Gemma model. Debounce: 2.5s after typing stops."
                                  FontSize="10" Foreground="{StaticResource RDATTextDimBrush}"
                                  Margin="0,-8,0,0"/>

                        <!-- Toggle: AMTA Lint -->
                        <ToggleSwitch
                                     IsOn="{x:Bind ViewModel.IsAmtaLintEnabled, Mode=TwoWay}"
                                     OnContent="Enabled" OffContent="Disabled">
                            <ToggleSwitch.Header>
                                <TextBlock Text="AMTA Terminology Linter" FontSize="12"
                                          Foreground="{StaticResource RDATTextBrush}"/>
                            </ToggleSwitch.Header>
                        </ToggleSwitch>
                        <TextBlock Text="Flags missing, inconsistent, or untranslated terms from the loaded glossary. Debounce: 2s."
                                  FontSize="10" Foreground="{StaticResource RDATTextDimBrush}"
                                  Margin="0,-8,0,0"/>

                        <!-- Toggle: Gemini Enhanced Grammar -->
                        <ToggleSwitch
                                     IsOn="{x:Bind ViewModel.IsGeminiGrammarEnabled, Mode=TwoWay}"
                                     OnContent="Enabled" OffContent="Disabled">
                            <ToggleSwitch.Header>
                                <TextBlock Text="Gemini Enhanced Grammar (Cloud)" FontSize="12"
                                          Foreground="{StaticResource RDATTextBrush}"/>
                            </ToggleSwitch.Header>
                        </ToggleSwitch>
                        <TextBlock Text="Uses Gemini 2.0 Flash for enhanced Arabic morphology analysis. Requires API key. Runs alongside local checker for comprehensive coverage."
                                  FontSize="10" Foreground="{StaticResource RDATTextDimBrush}"
                                  Margin="0,-8,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Phase 3: AI Models Section (Local LLM) -->
                <Border Background="{StaticResource RDATBgSecondaryBrush}"
                       BorderBrush="{StaticResource RDATBorderBrush}"
                       CornerRadius="8" Padding="20">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE945;" FontSize="14" Foreground="{StaticResource RDATTealBrush}"/>
                            <TextBlock Text="AI Models — نماذج الذكاء الاصطناعي" FontSize="14"
                                      Foreground="{StaticResource RDATTextBrush}"
                                      FontWeight="SemiBold"/>
                        </StackPanel>

                        <TextBlock Text="Configure the local LLM model for ghost text generation. Uses ONNX Runtime GenAI with DirectML for GPU/NPU acceleration. Gemma 2B IT INT4 quantized recommended."
                                  FontSize="12" Foreground="{StaticResource RDATTextMutedBrush}"
                                  TextWrapping="Wrap"/>

                        <!-- LLM Model Path -->
                        <StackPanel Spacing="6">
                            <TextBlock Text="LLM Model Path" FontSize="12"
                                      Foreground="{StaticResource RDATTextMutedBrush}"/>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBox x:Name="LlmModelPathBox"
                                        PlaceholderText="C:\Models\gemma-2b-it-q4f32_1-ONNX"
                                        Text="{x:Bind ViewModel.LlmModelPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        MinWidth="350"
                                        Background="{StaticResource RDATBgTertiaryBrush}"/>
                                <Button Content="&#xE8E5;" Click="BrowseLlmModel_Click"
                                       ToolTipService.ToolTip="Browse for LLM model folder"
                                       Padding="8" CornerRadius="4"
                                       Background="{StaticResource RDATBgTertiaryBrush}"
                                       BorderBrush="{StaticResource RDATBorderBrush}">
                                    <FontIcon Glyph="&#xE8DA;" FontSize="12"
                                             Foreground="{StaticResource RDATTextMutedBrush}"/>
                                </Button>
                            </StackPanel>
                            <TextBlock Text="Gemma 2B IT Q4 (ONNX format with DirectML support)"
                                      FontSize="10" Foreground="{StaticResource RDATTextDimBrush}"/>
                        </StackPanel>

                        <!-- Temperature Slider -->
                        <StackPanel Spacing="6">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <TextBlock Text="Temperature" FontSize="12"
                                          Foreground="{StaticResource RDATTextMutedBrush}"/>
                                <TextBlock Text="{x:Bind ViewModel.TemperatureDisplay, Mode=OneWay}"
                                          FontSize="12" Foreground="{StaticResource RDATTealBrush}"/>
                            </StackPanel>
                            <Slider x:Name="TemperatureSlider"
                                   Minimum="0.0" Maximum="1.0" StepFrequency="0.05"
                                   Value="{x:Bind ViewModel.LlmTemperature, Mode=TwoWay}"
                                   IsEnabled="{x:Bind ViewModel.IsLlmInitializing, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"/>
                            <TextBlock Text="Low = precise, High = creative (translation: 0.2-0.4 recommended)"
                                      FontSize="10" Foreground="{StaticResource RDATTextDimBrush}"/>
                        </StackPanel>

                        <!-- LLM Engine Status -->
                        <Border Background="{StaticResource RDATBgPrimaryBrush}"
                               BorderBrush="{StaticResource RDATBorderBrush}"
                               Padding="12" CornerRadius="4">
                            <StackPanel Spacing="6">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="LLM Engine Status" FontSize="12"
                                              Foreground="{StaticResource RDATTextMutedBrush}"
                                              FontWeight="SemiBold"/>
                                    <Ellipse Width="6" Height="6">
                                        <Ellipse.Fill>
                                            <SolidColorBrush Color="{StaticResource RDATTealPrimary}"/>
                                        </Ellipse.Fill>
                                    </Ellipse>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <TextBlock Text="State:" FontSize="11"
                                              Foreground="{StaticResource RDATTextDimBrush}"/>
                                    <TextBlock Text="{x:Bind ViewModel.LlmEngineState, Mode=OneWay}"
                                              FontSize="11"
                                              Foreground="{StaticResource RDATTextBrush}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <TextBlock Text="Queue:" FontSize="11"
                                              Foreground="{StaticResource RDATTextDimBrush}"/>
                                    <TextBlock Text="{x:Bind ViewModel.QueueStatus, Mode=OneWay}"
                                              FontSize="11"
                                              Foreground="{StaticResource RDATTextBrush}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Load/Unload LLM buttons -->
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="Load LLM Model" Click="LoadLlm_Click"
                                   Style="{StaticResource AccentButtonStyle}"
                                   Padding="20,8" CornerRadius="4"
                                   IsEnabled="{x:Bind ViewModel.IsLlmInitializing, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"/>
                            <Button Content="Unload" Click="UnloadLlm_Click"
                                   Background="{StaticResource RDATBgTertiaryBrush}"
                                   BorderBrush="{StaticResource RDATBorderBrush}"
                                   Padding="20,8" CornerRadius="4"/>
                        </StackPanel>

                        <!-- Channel Timings Info -->
                        <Border Background="{StaticResource RDATBgPrimaryBrush}"
                               BorderBrush="{StaticResource RDATBorderBrush}"
                               Padding="12" CornerRadius="4">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Channel Timings" FontSize="11"
                                          Foreground="{StaticResource RDATTextDimBrush}"
                                          FontWeight="SemiBold"/>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="Ch5 Burst:" FontSize="10" Foreground="{StaticResource RDATTextDimBrush}"/>
                                    <TextBlock Text="800ms debounce · 3-5 words · preempt prefetch" FontSize="10" Foreground="{StaticResource RDATTextMutedBrush}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="Ch6 Pause:" FontSize="10" Foreground="{StaticResource RDATTextDimBrush}"/>
                                    <TextBlock Text="1200ms debounce · 5-20 words · preempt all" FontSize="10" Foreground="{StaticResource RDATTextMutedBrush}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="Ch3 Prefetch:" FontSize="10" Foreground="{StaticResource RDATTextDimBrush}"/>
                                    <TextBlock Text="Immediate · 200 tokens · low priority" FontSize="10" Foreground="{StaticResource RDATTextMutedBrush}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="Ch4 Grammar:" FontSize="10" Foreground="#a78bfa"/>
                                    <TextBlock Text="2500ms debounce · structured JSON · non-preemptible" FontSize="10" Foreground="#c4b5fd"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Back Button -->
                <Button Content="← Back to Workspace" Click="Back_Click"
                       Background="Transparent" BorderThickness="0"
                       Padding="0" HorizontalAlignment="Left">
                    <Button.Foreground>
                        <SolidColorBrush Color="{StaticResource RDATTextMuted}"/>
                    </Button.Foreground>
                </Button>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
