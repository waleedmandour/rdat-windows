<Window
    x:Class="RDAT.Copilot.Desktop.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:RDAT.Copilot.Desktop"
    Title="RDAT Copilot — مساعد الترجمة الذكي">

    <Grid Background="{StaticResource RDATBgPrimaryBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>

        <!-- Custom Title Bar -->
        <Grid Grid.Row="0" Padding="12,0" Background="{StaticResource RDATStatusBarBrush}"
              VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <FontIcon Glyph="&#xE945;" FontSize="14" Foreground="{StaticResource RDATTealBrush}"/>
                <TextBlock Text="RDAT Copilot" FontSize="12"
                          Foreground="{StaticResource RDATTextBrush}"
                          VerticalAlignment="Center"
                          FontFamily="{StaticResource RDATFontFamily}"/>
                <TextBlock Text="مساعد الترجمة الذكي" FontSize="10"
                          Foreground="{StaticResource RDATTextMutedBrush}"
                          VerticalAlignment="Center" Margin="8,0,0,0"/>
            </StackPanel>

            <!-- Window controls placeholder (system buttons) -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                <TextBlock Text="v2.0.0" FontSize="10"
                          Foreground="{StaticResource RDATTextDimBrush}"
                          VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- Main Content Area — Frame for page navigation -->
        <Frame Grid.Row="1" x:Name="RootFrame"/>

        <!-- Status Bar -->
        <Grid Grid.Row="2" Padding="12,0" Background="{StaticResource RDATStatusBarBrush}"
              BorderBrush="{StaticResource RDATBorderBrush}" BorderThickness="0,1,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <FontIcon Glyph="&#xE945;" FontSize="10" Foreground="{StaticResource RDATTealBrush}"/>
                    <TextBlock Text="Hybrid (Local + Cloud)" FontSize="11"
                              Foreground="{StaticResource RDATTextMutedBrush}"
                              FontFamily="{StaticResource RDATFontFamily}"/>
                    <TextBlock Text="هجين" FontSize="9" Foreground="{StaticResource RDATTextDimBrush}"
                              Margin="4,0,0,0"/>
                </StackPanel>

                <TextBlock Text="│" FontSize="11" Foreground="{StaticResource RDATBorderBrush}"/>

                <StackPanel Orientation="Horizontal" Spacing="4">
                    <FontIcon Glyph="&#xE8AB;" FontSize="10" Foreground="{StaticResource RDATTextDimBrush}"/>
                    <TextBlock Text="LLM: Idle" FontSize="11"
                              Foreground="{StaticResource RDATTextMutedBrush}"/>
                </StackPanel>

                <TextBlock Text="│" FontSize="11" Foreground="{StaticResource RDATBorderBrush}"/>

                <StackPanel Orientation="Horizontal" Spacing="4">
                    <FontIcon Glyph="&#xE7C3;" FontSize="10" Foreground="{StaticResource RDATTextDimBrush}"/>
                    <TextBlock Text="GTR: Idle" FontSize="11"
                              Foreground="{StaticResource RDATTextMutedBrush}"/>
                </StackPanel>

                <TextBlock Text="│" FontSize="11" Foreground="{StaticResource RDATBorderBrush}"/>

                <StackPanel Orientation="Horizontal" Spacing="4">
                    <FontIcon Glyph="&#xE9D2;" FontSize="10" Foreground="{StaticResource RDATTextDimBrush}"/>
                    <TextBlock Text="Gemini: No Key" FontSize="11"
                              Foreground="{StaticResource RDATTextMutedBrush}"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock Text="EN → AR" FontSize="11"
                          Foreground="{StaticResource RDATTextMutedBrush}"/>
                <TextBlock Text="│" FontSize="11" Foreground="{StaticResource RDATBorderBrush}"/>
                <TextBlock Text="WebGPU Ready" FontSize="11"
                          Foreground="{StaticResource RDATTextDimBrush}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
